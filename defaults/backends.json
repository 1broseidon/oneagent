{
  "claude": {
    "run": "claude -p {prompt} --model {model} --output-format stream-json --include-partial-messages --verbose --dangerously-skip-permissions",
    "resume": "+ --resume {session}",
    "format": "jsonl",
    "prompt_stdin": true,
    "activity": "{message.content.0.name} {message.content.0.input.description} {message.content.0.input.file_path} {message.content.0.input.pattern}",
    "activity_when": "type=assistant&message.content.0.type=tool_use",
    "delta": "event.delta.text",
    "delta_when": "type=stream_event&event.type=content_block_delta&event.delta.type=text_delta",
    "result": "result",
    "result_when": "type=result&is_error=false",
    "session": "session_id",
    "session_when": "type=system",
    "error": "result",
    "error_when": "type=result&is_error=true",
    "model": "sonnet",
    "paths": ["~/.claude/local", "~/.local/bin", "~/.npm-global/bin"]
  },
  "codex": {
    "run": "codex exec - --json --dangerously-bypass-approvals-and-sandbox -C {cwd} --skip-git-repo-check",
    "resume": "codex exec resume {session} - --json --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check",
    "format": "jsonl",
    "prompt_stdin": true,
    "activity": "{item.command}",
    "activity_when": "type=item.started&item.type=command_execution",
    "delta": "assistantMessageEvent.delta",
    "delta_when": "type=message_update&assistantMessageEvent.type=text_delta",
    "result": "item.text",
    "result_when": "type=item.completed",
    "session": "thread_id",
    "session_when": "type=thread.started",
    "error": "message",
    "error_when": "type=error",
    "paths": ["~/.local/bin", "~/.npm-global/bin"]
  },
  "opencode": {
    "run": "opencode run {prompt} --format json --dir {cwd} --model {model}",
    "resume": "+ --session {session}",
    "format": "jsonl",
    "prompt_stdin": true,
    "activity": "{part.tool} {part.state.title} {part.state.input.filePath}",
    "activity_when": "type=tool_use",
    "result": "part.text",
    "result_when": "type=text",
    "session": "sessionID",
    "session_when": "type=step_start",
    "error": "part.text",
    "error_when": "type=error",
    "paths": ["~/.opencode/bin", "~/.local/bin"]
  },
  "pi": {
    "run": "pi -p {prompt} --mode json --model {model}",
    "resume": "+ --session {session}",
    "format": "jsonl",
    "prompt_stdin": true,
    "activity": "{assistantMessageEvent.toolCall.name} {assistantMessageEvent.toolCall.arguments.command} {assistantMessageEvent.toolCall.arguments.path}",
    "activity_when": "type=message_update&assistantMessageEvent.type=toolcall_end",
    "delta": "assistantMessageEvent.delta",
    "delta_when": "type=message_update&assistantMessageEvent.type=text_delta",
    "result": "message.content.-1.text",
    "result_when": "type=turn_end&message.content.-1.type=text",
    "session": "id",
    "session_when": "type=session",
    "error": "message",
    "error_when": "type=error",
    "paths": ["~/.local/bin", "~/.npm-global/bin"]
  },
  "gemini": {
    "run": "gemini -p {prompt} --model {model} --output-format stream-json --yolo",
    "format": "jsonl",
    "prompt_stdin": true,
    "activity": "{tool_name}",
    "activity_when": "type=tool_use",
    "delta": "content",
    "delta_when": "type=message&role=assistant&delta=true",
    "result": "content",
    "result_when": "type=message&role=assistant&delta=true",
    "result_append": true,
    "session": "session_id",
    "session_when": "type=init",
    "error": "output",
    "error_when": "type=tool_result&status=error",
    "model": "auto-gemini-3",
    "paths": ["/home/linuxbrew/.linuxbrew/bin", "~/.local/bin", "~/.npm-global/bin"]
  }
}
